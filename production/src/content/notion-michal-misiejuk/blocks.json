  {
    "id": "2933d5f4-a00c-8042-a9e1-ea8fbf9b6c71",
    "type": "text",
    "images": [],
    "text": "As part of the early-stage development of Kleks Academy, I led the product discovery process, focusing on translating business goals and creative vision into a clear, actionable product concept. I gathered and consolidated business and stakeholder requirements, ensuring alignment across multiple disciplines.",
    "links": [],
    "localImages": []
  },
